{
  "name": "redbull-application-experience",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "db:apply": "npx wrangler d1 execute redbull_tracking --file db/schema.sql",
    "deploy": "npm run build && npx wrangler deploy"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "framer-motion": "^12.18.1",
    "gsap": "^3.13.0",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.60.0"
  }
}
